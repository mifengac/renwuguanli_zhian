# 数据库连接（注意：密码里有特殊字符（如 @）时需要 URL 编码，例如 @ -> %40）
# 本项目 docker-compose-offline.yml 的默认密码是：Asd@199312
DATABASE_URL="postgresql://postgres:Asd%40199312@localhost:5432/postgres?schema=public"

# JWT 密钥（开发环境可随便填，生产环境请使用强随机值）
JWT_SECRET="change_me_in_production"

# MinIO 配置（本地用 docker-compose-offline.yml 启动 minio 时）
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="zhian_fujian"
MINIO_USE_SSL="false"

# Cookie secure（本地 http 访问建议 false）
COOKIE_SECURE="false"
MONITOR_JOB_TOKEN="change_me_for_internal_cron"
MONITOR_INSTANCE_LOOKAHEAD_DAYS="60"
MONITOR_INSTANCE_BACKFILL_DAYS="7"
MONITOR_NOTIFY_RETRY_LIMIT="5"
MONITOR_SMS_DRIVER="mock"
ORACLE_SMS_USER=""
ORACLE_SMS_PASSWORD=""
ORACLE_SMS_CONNECT_STRING=""
ORACLE_SMS_TABLE="SMS_QUEUE"
# ORACLE_SMS_INSERT_SQL="INSERT INTO SMS_QUEUE (EID, MOBILE, CONTENT, PUSH_TIME, CREATED_AT) VALUES (:eid, :mobile, :content, :pushTime, :createdAt)"
